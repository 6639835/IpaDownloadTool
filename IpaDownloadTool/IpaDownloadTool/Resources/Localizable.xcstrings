{
  "sourceLanguage": "en",
  "strings": {
    "agreement.accept": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Agree and Continue"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同意并继续"
          }
        }
      }
    },
    "agreement.body": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. IPA Download Tool is designed to extract ipa information from third-party web pages for learning and testing only. Do not use it for any illegal or abusive purpose.\n\n2. The app doesn't support extracting ipa files from the App Store or from apps already installed on this device.\n\n3. Link history, extraction history, and downloaded files are stored locally on device and aren't uploaded to the cloud.\n\n4. You can launch the app directly from Safari with ipadownloadtool://hander?url=."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. “IPA提取器”用于提取第三方网页中的 ipa 信息，仅限学习交流，不得用于违法违规用途。\n\n2. 本应用不支持提取 App Store 的 ipa，也不支持导出本机已安装 App 的 ipa。\n\n3. 链接历史、提取历史、下载文件均默认保存在本机，不上传云端。\n\n4. 通过 ipadownloadtool://hander?url= 可直接从 Safari 唤起本应用并加载链接。"
          }
        }
      }
    },
    "agreement.heading.detail": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 26 enables Liquid Glass automatically. Review the usage boundaries before continuing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 26 会自动启用 Liquid Glass。继续前请先确认应用使用边界。"
          }
        }
      }
    },
    "agreement.heading.eyebrow": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
